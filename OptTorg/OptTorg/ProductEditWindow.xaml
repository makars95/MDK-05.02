<Window x:Class="OptTorg.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:OptTorg.Converters"
        mc:Ignorable="d"
        Title="Редактирование товара" 
        Height="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="500"
        MinWidth="500"
        MaxWidth="500"
        Background="{DynamicResource BgMedium}">

    <Window.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:ImagePathConverter x:Key="ImagePathConverter"/>
    </Window.Resources>

    <Border Background="{DynamicResource BgCard}" CornerRadius="15" Margin="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource PrimaryBlue}" Padding="15">
                <Grid>
                    <TextBlock x:Name="TitleText" 
                               Text="Добавление товара" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
                <StackPanel>
                    <TextBlock Text="Наименование *" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,5"/>
                    <TextBox x:Name="NaimenovanieTextBox" 
                             Style="{DynamicResource BaseTextBoxStyle}"
                             Height="40"
                             Margin="0,0,0,15"/>
                    <TextBlock Text="Артикул *" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,5"/>
                    <TextBox x:Name="ArtikulTextBox" 
                             Style="{DynamicResource BaseTextBoxStyle}"
                             Height="40"
                             Margin="0,0,0,15"/>
                    <TextBlock Text="Категория *" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CategoryComboBox"
                              Style="{DynamicResource BaseComboBoxStyle}"
                              Height="40"
                              DisplayMemberPath="Name"
                              Margin="0,0,0,15"/>
                    <TextBlock Text="Производитель *" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,5"/>
                    <TextBox x:Name="ProizvoditelTextBox" 
                             Style="{DynamicResource BaseTextBoxStyle}"
                             Height="40"
                             Margin="0,0,0,15"/>

                    <TextBlock Text="Единица измерения *" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,5"/>
                    <ComboBox x:Name="EdinicaComboBox"
                              Style="{DynamicResource BaseComboBoxStyle}"
                              Height="40"
                              Margin="0,0,0,15">
                        <ComboBoxItem Content="шт"/>
                        <ComboBoxItem Content="кг"/>
                        <ComboBoxItem Content="л"/>
                    </ComboBox>

                    <TextBlock Text="Описание *" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,5"/>
                    <TextBox x:Name="OpisanieTextBox" 
                             Style="{DynamicResource BaseTextBoxStyle}"
                             Height="100"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,15"/>
                    <TextBlock Text="Изображение" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,5"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="SelectImageButton" 
                                Content="📷 Выбрать изображение"
                                Width="150"
                                Height="35"
                                Grid.Column="0"
                                Background="{DynamicResource PrimaryBlue}"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="SelectImageButton_Click"/>

                        <Border Grid.Column="1"
                                Width="80" 
                                Height="80" 
                                Margin="10,0,0,0"
                                Background="{DynamicResource BgInput}"
                                BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="1">
                            <Image x:Name="ImagePreview"
                                   Stretch="Uniform"/>
                        </Border>
                    </Grid>

                    <StackPanel x:Name="CurrentImagePanel">
                        <TextBlock x:Name="CurrentImageLabel" 
                                    Text="Текущее изображение:" 
                                    Style="{StaticResource FieldLabelStyle}" 
                                    Margin="0,0,0,5"
                                    Visibility="Collapsed"/>
                        <Border x:Name="CurrentImageBorder"
                                Width="100" 
                                Height="100" 
                                Margin="0,0,0,15"
                                Background="{DynamicResource BgInput}"
                                BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="1"
                                Visibility="Collapsed">
                            <Image x:Name="CurrentImage"
                                   Stretch="Uniform"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0" Padding="20">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="SaveButton" 
                            Content="💾 Сохранить" 
                            Width="140" 
                            Height="40"
                            Margin="0,0,15,0"
                            Background="{DynamicResource SuccessGreen}"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontWeight="SemiBold"
                            Click="SaveButton_Click"/>
                    <Button x:Name="CancelButton" 
                            Content="❌ Отмена" 
                            Width="140" 
                            Height="40"
                            Background="{DynamicResource ErrorRed}"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontWeight="SemiBold"
                            Click="CancelButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>