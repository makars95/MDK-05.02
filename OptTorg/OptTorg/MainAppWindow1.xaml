<Window x:Class="OptTorg.MainAppWindow1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:OptTorg.ViewModels"
        xmlns:pages="clr-namespace:OptTorg.Pages"
        xmlns:converters="clr-namespace:OptTorg.Converters"
        mc:Ignorable="d"
        Title="OptTorg - Управление торговлей ЛКМ" 
        Height="700" 
        Width="1200"
        MinHeight="500"
        MinWidth="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent"
        Closed="Window_Closed">

    <Window.Resources>
        <!-- Стиль для кнопки сворачивания -->
        <Style x:Key="WindowButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="45"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                    <Setter Property="Background" Value="{DynamicResource BgInput}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavExitButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource ErrorRed}"/>
                    <Setter Property="Background" Value="{DynamicResource BgInput}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для элементов ListBox -->
        <Style x:Key="NavListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border"
                                Background="Transparent"
                                Padding="20,12"
                                Margin="8,3"
                                CornerRadius="10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Icon}" 
                                           FontSize="14" 
                                           Foreground="{DynamicResource TextSecondary}"
                                           Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding Title}" 
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource BgInput}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource PrimaryBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="ItemContainerStyle" Value="{DynamicResource NavListBoxItemStyle}"/>
        </Style>

        <!-- DataTemplate -->
        <DataTemplate DataType="{x:Type viewmodels:CatalogViewModel}">
            <pages:CatalogPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:ClientsViewModel}">
            <pages:ClientsPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:ContractsViewModel}">
            <pages:ContractsPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:OrdersViewModel}">
            <pages:OrdersPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:StockViewModel}">
            <pages:StockPage/>
        </DataTemplate>
    </Window.Resources>

    <Border Background="{DynamicResource BgGradient}" CornerRadius="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ЗАГОЛОВОК ОКНА -->
            <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" 
                    CornerRadius="15,15,0,0"
                    Background="{DynamicResource BgDark}">
                <Grid>
                    <!-- Область для перетаскивания окна -->
                    <Border Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>

                    <!-- Кнопки управления окном -->
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Right" 
                                VerticalAlignment="Center"
                                Margin="0,0,10,0">

                        <!-- Кнопка переключения темы -->
                        <ToggleButton x:Name="ThemeToggleButton"
                                      Style="{DynamicResource ThemeToggleButtonStyle}"
                                      Click="ThemeToggleButton_Click"
                                      Margin="0,0,5,0"/>

                        <!-- Кнопка свернуть -->
                        <Button Style="{DynamicResource WindowButtonStyle}"
                                Click="MinimizeButton_Click"
                                Content="─"/>

                        <!-- Кнопка развернуть/восстановить -->
                        <Button x:Name="MaximizeButton"
                                Style="{DynamicResource WindowButtonStyle}"
                                Click="MaximizeButton_Click"
                                Content="□"/>

                        <!-- Кнопка закрыть -->
                        <Button Style="{DynamicResource WindowButtonStyle}"
                                Click="CloseButton_Click"
                                Content="✕"
                                Foreground="{DynamicResource ErrorRed}">
                            <Button.Triggers>
                                <EventTrigger RoutedEvent="Button.MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation To="#e74c3c" 
                                                            Storyboard.TargetProperty="Background.Color"
                                                            Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Button.Triggers>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ЛЕВАЯ ПАНЕЛЬ -->
            <Border Grid.Row="1" Grid.Column="0" 
                    Background="{DynamicResource BgDark}"
                    CornerRadius="0,0,0,15">
                <DockPanel>
                    <!-- Логотип -->
                    <Border DockPanel.Dock="Top" Padding="0,20,0,20">
                        <StackPanel HorizontalAlignment="Center">
                            <Border Grid.Row="0" 
                                    Style="{DynamicResource LogoBorderStyle}"
                                    Margin="0,0,0,5">
                                <Image Source="Resources/Images/logo2.png" 
                                       Style="{DynamicResource RoundedImageStyle}"/>
                            </Border>
                            <TextBlock Text="OptTorgKrask" 
                                       FontSize="22" 
                                       FontWeight="Bold" 
                                       Foreground="{DynamicResource TextPrimary}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Лакокрасочные материалы" 
                                       FontSize="11" 
                                       Foreground="{DynamicResource TextSecondary}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Навигация -->
                    <ListBox x:Name="NavigationListBox"
                             Style="{DynamicResource NavListBoxStyle}"
                             ItemsSource="{Binding ViewModelsCollection}"
                             SelectedItem="{Binding SelectedViewModel}"
                             DockPanel.Dock="Top"
                             Margin="10,20,10,0"/>

                    <!-- Панель пользователя (нижняя часть левой панели) -->
                    <Border DockPanel.Dock="Bottom" 
                            Background="{DynamicResource BgDark}"
                            Padding="15,15"
                            CornerRadius="0,0,0,15">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="50" Height="50" CornerRadius="25"
                                        Background="{DynamicResource PrimaryBlue}"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="👤" FontSize="28" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock FontSize="14" FontWeight="Bold" 
                                               Foreground="{DynamicResource TextPrimary}"
                                               Text="{Binding UserFullName}"/>
                                    <TextBlock FontSize="11" 
                                               Foreground="{DynamicResource TextSecondary}"
                                               Text="Сотрудник OptTorgKrask"/>
                                </StackPanel>
                            </StackPanel>

                            <Button Style="{DynamicResource NavExitButtonStyle}"
                                    Click="ExitButton_Click"
                                    Content="🚪 Выйти"/>
                        </StackPanel>
                    </Border>
                </DockPanel>
            </Border>

            <!-- ==================== РАБОЧАЯ ОБЛАСТЬ ==================== -->
            <Border Grid.Row="1" Grid.Column="1" 
                    Background="{DynamicResource BgMedium}"
                    CornerRadius="0,0,15,15">
                <Frame NavigationUIVisibility="Hidden" Content="{Binding SelectedViewModel}"/>
            </Border>

            <!-- Уголок для изменения размера окна -->
            <Border Grid.Row="1" Grid.Column="1" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Bottom"
                    Width="15" Height="15"
                    Background="Transparent"
                    Cursor="SizeNWSE">
                <Border MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown"/>
            </Border>
        </Grid>
    </Border>
</Window>