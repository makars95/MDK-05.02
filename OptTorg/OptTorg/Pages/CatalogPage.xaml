<Page x:Class="OptTorg.Pages.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:converters="clr-namespace:OptTorg.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1100"
      Title="{Binding Title}"
      Background="{DynamicResource BgMedium}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:ImagePathConverter x:Key="ImagePathConverter"/>

        <!-- Стиль для заголовков -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource PrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" 
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"/>
                                <Path Grid.Column="1"
                                      x:Name="SortArrow"
                                      Width="8" Height="8"
                                      Margin="8,0,0,0"
                                      Stretch="Fill"
                                      Fill="White"
                                      Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="SortDirection" Value="Ascending">
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="SortArrow" Property="Data" Value="M0,5 L4,0 L8,5 Z"/>
                            </Trigger>
                            <Trigger Property="SortDirection" Value="Descending">
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="SortArrow" Property="Data" Value="M0,0 L4,5 L8,0 Z"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для строк -->
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource BgCard}"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BgInput}"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryBlue}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#1a2a4a"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для ячеек -->
        <Style TargetType="DataGridCell">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Стиль для таблицы -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RowHeight" Value="46"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="AlternationCount" Value="2"/>
        </Style>

        <Style x:Key="CustomTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Background="Transparent" CornerRadius="8" Padding="20,10" Margin="5,0">
                            <ContentPresenter x:Name="ContentSite" ContentSource="Header"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource PrimaryBlue}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource BgInput}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Background="{DynamicResource BgCard}" 
                CornerRadius="10,10,0,0"
                Padding="15"
                Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <TextBlock Text="🎨 " FontSize="24"/>
                    <TextBlock Text="{Binding Title}" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Grid.Column="2">
                    <Button Content="➕ Добавить"
                            Width="120"
                            Height="35"
                            Command="{Binding AddCommand}"
                            Background="{DynamicResource SuccessGreen}"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Панель фильтрации -->
        <Border Grid.Row="1"
                Background="{DynamicResource BgCard}"
                CornerRadius="8"
                Padding="15"
                Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <TextBlock Text="🔍 Поиск" Foreground="{DynamicResource PrimaryBlue}" FontWeight="SemiBold" Margin="0,0,0,6" FontSize="12"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource BaseTextBoxStyle}"
                             Height="36"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,15,0">
                    <TextBlock Text="📂 Категория" Foreground="{DynamicResource PrimaryBlue}" FontWeight="SemiBold" Margin="0,0,0,6" FontSize="12"/>
                    <ComboBox ItemsSource="{Binding CategoryNames}"
                              SelectedItem="{Binding SelectedCategoryFilter}"
                              Style="{DynamicResource BaseComboBoxStyle}"
                              Height="36"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="🏭 Производитель" Foreground="{DynamicResource PrimaryBlue}" FontWeight="SemiBold" Margin="0,0,0,6" FontSize="12"/>
                    <ComboBox ItemsSource="{Binding Manufacturers}"
                              SelectedItem="{Binding SelectedManufacturerFilter}"
                              Style="{DynamicResource BaseComboBoxStyle}"
                              Height="36"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Таблица товаров -->
        <TabControl Grid.Row="2"
                    Background="Transparent"
                    BorderThickness="0"
                    ItemContainerStyle="{StaticResource CustomTabItemStyle}">

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊 " Margin="0,0,5,0"/>
                        <TextBlock Text="Таблица товаров"/>
                    </StackPanel>
                </TabItem.Header>

                <Grid Background="{DynamicResource BgMedium}" Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid Grid.Row="0"
                              ItemsSource="{Binding FilteredTovary}"
                              SelectedItem="{Binding SelectedTovar}"
                              AlternationCount="2">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Tovar_id}" Width="55">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Артикул" Binding="{Binding Artikul}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBlue}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                        <Setter Property="Tag" Value="Artikul"/>
                                        <EventSetter Event="Click" Handler="SortColumn_Click"/>
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Наименование" Binding="{Binding Naimenovanie}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                        <Setter Property="Tag" Value="Naimenovanie"/>
                                        <EventSetter Event="Click" Handler="SortColumn_Click"/>
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Описание" Binding="{Binding Opisanie}" Width="250">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Категория" Binding="{Binding Nazvanie_kategorii}" Width="130"/>

                            <DataGridTextColumn Header="Производитель" Binding="{Binding Proizvoditel}" Width="150"/>

                            <DataGridTextColumn Header="Ед. изм." Binding="{Binding Edinica_izmereniya}" Width="85">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Нижняя панель -->
                    <Border Grid.Row="1" 
                            Background="{DynamicResource BgCard}" 
                            CornerRadius="8" 
                            Padding="12,10"
                            Margin="0,10,0,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <Button Content="✏️ Редактировать"
                                        Width="120"
                                        Height="32"
                                        Margin="0,0,10,0"
                                        Command="{Binding EditCommand}"
                                        Background="{DynamicResource PrimaryBlue}"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        FontSize="12"/>
                                <Button Content="🗑️ Удалить"
                                        Width="100"
                                        Height="32"
                                        Command="{Binding DeleteCommand}"
                                        Background="{DynamicResource ErrorRed}"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        FontSize="12"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="📊 Всего: " Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                <TextBlock Text="{Binding FilteredTovary.Count}" 
                                           Foreground="{DynamicResource PrimaryBlue}"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           Margin="3,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Вкладка 2: Карточки товаров -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🖼️ " Margin="0,0,5,0"/>
                        <TextBlock Text="Карточки товаров"/>
                    </StackPanel>
                </TabItem.Header>

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding FilteredTovary}" Margin="0,10,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="300"
                                        Margin="10"
                                        Background="{DynamicResource BgCard}"
                                        CornerRadius="12"
                                        BorderBrush="{DynamicResource BorderColor}"
                                        BorderThickness="1"
                                        Cursor="Hand">
                                    <Grid Margin="12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0"
                                                Height="180"
                                                CornerRadius="8"
                                                Background="{DynamicResource BgInput}"
                                                Margin="0,0,0,10">
                                            <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}"
                                                   Stretch="Uniform"
                                                   StretchDirection="Both"/>
                                        </Border>

                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                                            <Border Background="{DynamicResource PrimaryBlue}" CornerRadius="10" Padding="8,3">
                                                <TextBlock Text="{Binding Artikul, StringFormat='Арт: {0}'}" 
                                                           FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                            </Border>
                                            <Border Background="{DynamicResource BgInput}" CornerRadius="10" Padding="8,3" Margin="5,0,0,0">
                                                <TextBlock Text="{Binding Nazvanie_kategorii}" FontSize="10" Foreground="{DynamicResource TextSecondary}"/>
                                            </Border>
                                        </StackPanel>

                                        <TextBlock Grid.Row="2"
                                                   Text="{Binding Naimenovanie}"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,8"/>

                                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,5">
                                            <TextBlock Text="🏭 " FontSize="12"/>
                                            <TextBlock Text="Производитель: " FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                                            <TextBlock Text="{Binding Proizvoditel}" FontSize="11" FontWeight="SemiBold" 
                                                       Foreground="{DynamicResource PrimaryBlue}" TextWrapping="Wrap" MaxWidth="180"/>
                                        </StackPanel>

                                        <TextBlock Grid.Row="5"
                                                   Text="{Binding Opisanie}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="60"
                                                   Margin="0,5,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Page>