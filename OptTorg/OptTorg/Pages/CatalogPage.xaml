<Page x:Class="OptTorg.Pages.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:converters="clr-namespace:OptTorg.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1100"
      Title="{Binding Title}"
      Background="{DynamicResource BgMedium}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:ImagePathConverter x:Key="ImagePathConverter"/>
    </Page.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource BgCard}" 
                CornerRadius="10,10,0,0"
                Padding="10"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <TextBlock Text="🎨 " FontSize="24"/>
                    <TextBlock Text="{Binding Title}" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Grid.Column="2">
                    <Button Content="➕ Добавить"
                            Width="120"
                            Height="35"
                            Command="{Binding AddCommand}"
                            Background="{DynamicResource SuccessGreen}"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{DynamicResource BgCard}"
                CornerRadius="8"
                Padding="15"
                Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Margin="0,0,15,0">
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="🔍 Поиск" 
                                   Foreground="{DynamicResource PrimaryBlue}" 
                                   FontWeight="SemiBold" 
                                   Margin="0,0,0,6" 
                                   FontSize="12"/>
                        <Grid>
                            <TextBox x:Name="SearchTextBox"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource BaseTextBoxStyle}"
                                     Height="36"
                                     Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock x:Name="SearchPlaceholder"
                                       Text="Поиск по наименованию, артикулу, производителю..."
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#9ACEEB"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsKeyboardFocused, ElementName=SearchTextBox}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="📂 Категории" 
                                   Foreground="{DynamicResource PrimaryBlue}" 
                                   FontWeight="SemiBold" 
                                   Margin="0,0,0,6" 
                                   FontSize="12"/>
                        <ListBox x:Name="CategoryListBox"
                                 ItemsSource="{Binding CategoryNames}"
                                 SelectionMode="Multiple"
                                 BorderThickness="0"
                                 Background="Transparent">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding}"
                                      IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                      Margin="0,0,10,5"
                                      Style="{DynamicResource FilterCheckBoxStyle}"
                                      Checked="FilterCheckBox_Changed"
                                      Unchecked="FilterCheckBox_Changed"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="🏭 Производители" 
                                   Foreground="{DynamicResource PrimaryBlue}" 
                                   FontWeight="SemiBold" 
                                   Margin="0,0,0,6" 
                                   FontSize="12"/>
                        <ListBox x:Name="ManufacturerListBox"
                                 ItemsSource="{Binding Manufacturers}"
                                 SelectionMode="Multiple"
                                 BorderThickness="0"
                                 Background="Transparent">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding}"
                                      IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                      Margin="0,0,10,5"
                                      Style="{DynamicResource FilterCheckBoxStyle}"
                                      Checked="FilterCheckBox_Changed"
                                      Unchecked="FilterCheckBox_Changed"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1">
                    <TextBlock Text="📋 Сортировка" 
                               Foreground="{DynamicResource PrimaryBlue}" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,6" 
                               FontSize="12"/>
                    <ComboBox x:Name="SortComboBox"
                              SelectedIndex="{Binding SelectedSort}"
                              Style="{DynamicResource BaseComboBoxStyle}"
                              Height="36"
                              SelectionChanged="SortComboBox_SelectionChanged">
                        <ComboBoxItem Content="По наименованию (А-Я)"/>
                        <ComboBoxItem Content="По наименованию (Я-А)"/>
                        <ComboBoxItem Content="По артикулу (возр.)"/>
                        <ComboBoxItem Content="По артикулу (убыв.)"/>
                    </ComboBox>
                </StackPanel>

                <Border Grid.Row="1" Grid.Column="1" 
                        Background="{DynamicResource BgInput}" 
                        CornerRadius="6" 
                        Padding="10" 
                        Margin="0,10,0,0"
                        VerticalAlignment="Bottom">
                    <StackPanel>
                        <TextBlock Text="Результаты поиска:" 
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Margin="0,0,0,5"/>
                        <TextBlock FontSize="20" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource TextPrimary}"
                                   HorizontalAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} из {1}">
                                    <Binding Path="CurrentCountElements"/>
                                    <Binding Path="CountAllElements"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <TabControl Grid.Row="2"
                    Background="Transparent"
                    BorderThickness="0"
                    ItemContainerStyle="{StaticResource CustomTabItemStyle}">

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊 " Margin="0,0,5,0"/>
                        <TextBlock Text="Таблица товаров"/>
                    </StackPanel>
                </TabItem.Header>

                <Grid Background="{DynamicResource BgMedium}" Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid Grid.Row="0"
                              ItemsSource="{Binding FilteredTovary}"
                              SelectedItem="{Binding SelectedTovar}"
                              AlternationCount="2">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Tovar_id}" Width="40">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Артикул" Binding="{Binding Artikul}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Наименование" Binding="{Binding Naimenovanie}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Описание" Binding="{Binding Opisanie}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Категория" Binding="{Binding Nazvanie_kategorii}" Width="120"/>

                            <DataGridTextColumn Header="Производитель" Binding="{Binding Proizvoditel}" Width="150"/>

                            <DataGridTextColumn Header="Ед. изм." Binding="{Binding Edinica_izmereniya}" Width="75">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="1" 
                            Background="{DynamicResource BgCard}" 
                            CornerRadius="8" 
                            Padding="12,10"
                            Margin="0,10,0,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <Button Content="✏️ Редактировать"
                                        Width="120"
                                        Height="32"
                                        Margin="0,0,10,0"
                                        Command="{Binding EditCommand}"
                                        Background="{DynamicResource PrimaryBlue}"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        FontSize="12"/>
                                <Button Content="🗑️ Удалить"
                                        Width="100"
                                        Height="32"
                                        Command="{Binding DeleteCommand}"
                                        Background="{DynamicResource ErrorRed}"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        FontSize="12"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="📊 Всего: " Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                <TextBlock Text="{Binding FilteredTovary.Count}" 
                                           Foreground="{DynamicResource PrimaryBlue}"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           Margin="3,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🖼️ " Margin="0,0,5,0"/>
                        <TextBlock Text="Карточки товаров"/>
                    </StackPanel>
                </TabItem.Header>

                <Grid Background="{DynamicResource BgMedium}" Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" 
                                  VerticalScrollBarVisibility="Auto" 
                                  HorizontalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
                        <ListBox ItemsSource="{Binding FilteredTovary}"
                                 SelectedItem="{Binding SelectedTovar}"
                                 SelectionMode="Single"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" 
                                   HorizontalAlignment="Left"
                                   ItemWidth="320"
                                   MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Border" 
                                                        Background="{TemplateBinding Background}"
                                                        Padding="0"
                                                        Margin="0">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="Transparent"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="Transparent"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="CardBorder"
                                            Width="300"
                                            Margin="10"
                                            Background="{DynamicResource BgCard}"
                                            CornerRadius="12"
                                            BorderBrush="{DynamicResource BorderColor}"
                                            BorderThickness="2">
                                        <Grid Margin="10">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Border Grid.Row="0"
                                                    Height="180"
                                                    CornerRadius="8"
                                                    Background="{DynamicResource BgInput}"
                                                    Margin="0,0,0,10">
                                                <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}"
                                                       Stretch="Uniform"
                                                       StretchDirection="Both"/>
                                            </Border>

                                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Background="{DynamicResource PrimaryBlue}" CornerRadius="10" Padding="8,3">
                                                    <TextBlock Text="{Binding Artikul, StringFormat='Арт: {0}'}" 
                                                               FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                                <Border Background="{DynamicResource PrimaryBlue}" CornerRadius="10" Padding="8,3" Margin="5,0,0,0">
                                                    <TextBlock Text="{Binding Nazvanie_kategorii}" 
                                                               FontSize="10" 
                                                               FontWeight="SemiBold"
                                                               Foreground="White"/>
                                                </Border>
                                            </StackPanel>

                                            <TextBlock Grid.Row="2"
                                                       Text="{Binding Naimenovanie}"
                                                       FontWeight="Bold"
                                                       FontSize="14"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,8"/>

                                            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,5">
                                                <TextBlock Text="🏭 " FontSize="12"/>
                                                <TextBlock Text="Производитель: " FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Text="{Binding Proizvoditel}" FontSize="11" FontWeight="SemiBold" 
                                                 Foreground="{DynamicResource PrimaryBlue}" TextWrapping="Wrap" MaxWidth="180"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,5">
                                                <TextBlock Text="📏 " FontSize="12"/>
                                                <TextBlock Text="Ед. изм.: " FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Text="{Binding Edinica_izmereniya}" FontSize="11" FontWeight="SemiBold" 
                                               Foreground="{DynamicResource TextPrimary}"/>
                                            </StackPanel>

                                            <TextBlock Grid.Row="5"
                                                       Text="{Binding Opisanie}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="60"
                                                       Margin="0,5,0,0"/>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                            <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBlue}"/>
                                            <Setter TargetName="CardBorder" Property="BorderThickness" Value="3"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>

                    <Border Grid.Row="1" 
                            Background="{DynamicResource BgCard}" 
                            CornerRadius="8" 
                            Padding="12,10"
                            Margin="0,10,0,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <Button Content="✏️ Редактировать"
                                        Width="120"
                                        Height="32"
                                        Margin="0,0,10,0"
                                        Command="{Binding EditCommand}"
                                        Background="{DynamicResource PrimaryBlue}"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        FontSize="12"/>
                                <Button Content="🗑️ Удалить"
                                        Width="100"
                                        Height="32"
                                        Command="{Binding DeleteCommand}"
                                        Background="{DynamicResource ErrorRed}"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        FontSize="12"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="📊 Всего: " Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                <TextBlock Text="{Binding FilteredTovary.Count}" 
                                           Foreground="{DynamicResource PrimaryBlue}"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           Margin="3,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>