<Page x:Class="OptTorg.Pages.ContractsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="{Binding Title}"
      Background="{DynamicResource BgMedium}">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource BgCard}" 
                CornerRadius="10,10,0,0"
                Padding="15"
                Margin="0,0,0,20">
            <TextBlock Text="{Binding Title}" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="{DynamicResource TextPrimary}"/>
        </Border>

        <Border Grid.Row="1"
                Background="{DynamicResource BgCard}"
                CornerRadius="10"
                Padding="25">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="📄" FontSize="64" HorizontalAlignment="Center"/>
                <TextBlock Text="Здесь будут договоры с клиентами и поставщиками"
                           FontSize="16"
                           Foreground="{DynamicResource TextSecondary}"
                           TextAlignment="Center"
                           Margin="0,15,0,0"/>
                <TextBlock Text="Функционал в разработке..."
                           FontSize="12"
                           Foreground="{DynamicResource WarningOrange}"
                           TextAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>