<Window x:Class="Optovaya_companya.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Демонстрация стилей OptTorgKrask"
        Height="800" 
        Width="900"
        MinHeight="700" 
        MinWidth="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource AliceBlueBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resource/Theme/DefaultTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок окна -->
        <Border Grid.Row="0" 
                Style="{StaticResource CardPanelStyle}"
                Margin="0,0,0,15">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="🎨 Демонстрация стилей" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource RoyalBlueBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>
                <TextBlock Text="Все элементы интерфейса используют стили из DefaultTheme.xaml" 
                           Foreground="{StaticResource AccentDarkGrayBrush}"
                           HorizontalAlignment="Center"
                           FontSize="14"/>
            </StackPanel>
        </Border>

        <!-- Основной контент со скроллом -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- Секция 1: Кнопки -->
                <Border Style="{StaticResource CardPanelStyle}">
                    <StackPanel>
                        <TextBlock Text="🔘 КНОПКИ" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource RoyalBlueBrush}"
                                   Margin="0,0,0,15"/>

                        <TextBlock Text="Обычные кнопки:" 
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Стандартная кнопка" Width="150"/>
                            <Button Content="Неактивная кнопка" Width="150" IsEnabled="False"/>
                        </StackPanel>

                        <TextBlock Text="Акцентная кнопка:" 
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <Button Content="Золотая кнопка" 
                                Style="{StaticResource AccentButtonStyle}" 
                                Width="200"
                                Margin="5,0,0,10"/>

                        <TextBlock Text="Кнопка пароля:" 
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <Button Content="👁️" 
                                Style="{StaticResource TogglePasswordButtonStyle}"
                                Width="35"
                                Margin="5,0,0,10"/>
                    </StackPanel>
                </Border>

                <!-- Секция 2: Текстовые поля -->
                <Border Style="{StaticResource CardPanelStyle}" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="📝 ТЕКСТОВЫЕ ПОЛЯ" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource RoyalBlueBrush}"
                                   Margin="0,0,0,15"/>

                        <TextBlock Text="Обычное текстовое поле:" 
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="Пример текста" Width="300" Margin="5,0,0,10"/>

                        <TextBlock Text="Многострочное поле:" 
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="Многострочный&#x0a;текст" 
                                 Style="{StaticResource MultilineTextBoxStyle}" 
                                 Width="300"
                                 Margin="5,0,0,10"/>

                        <TextBlock Text="Поле пароля:" 
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <PasswordBox Password="password123" 
                                     Style="{StaticResource BasePasswordBoxStyle}"
                                     Width="300"
                                     Margin="5,0,0,10"/>
                    </StackPanel>
                </Border>

                <!-- Секция 3: Выпадающие списки -->
                <Border Style="{StaticResource CardPanelStyle}" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="📋 ВЫПАДАЮЩИЕ СПИСКИ" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource RoyalBlueBrush}"
                                   Margin="0,0,0,15"/>

                        <TextBlock Text="ComboBox:" 
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox Width="300" Margin="5,0,0,10">
                            <ComboBoxItem Content="Опция 1" IsSelected="True"/>
                            <ComboBoxItem Content="Опция 2"/>
                            <ComboBoxItem Content="Опция 3"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Секция 4: Чекбоксы и радио-кнопки -->
                <Border Style="{StaticResource CardPanelStyle}" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="☑️ ЧЕКБОКСЫ И РАДИО-КНОПКИ" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource RoyalBlueBrush}"
                                   Margin="0,0,0,15"/>

                        <CheckBox Content="Чекбокс 1" Margin="5,2"/>
                        <CheckBox Content="Чекбокс 2 (отмечен)" IsChecked="True" Margin="5,2"/>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <RadioButton Content="Радио 1" IsChecked="True" Margin="5,2"/>
                            <RadioButton Content="Радио 2" Margin="5,2"/>
                            <RadioButton Content="Радио 3" Margin="5,2"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Секция 5: Таблица -->
                <Border Style="{StaticResource CardPanelStyle}" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="📊 ТАБЛИЦА (DataGrid)" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource RoyalBlueBrush}"
                                   Margin="0,0,0,15"/>

                        <DataGrid Height="200" 
                                  AutoGenerateColumns="False"
                                  Margin="5">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Width="60" Binding="{Binding Id}"/>
                                <DataGridTextColumn Header="Имя" Width="150" Binding="{Binding Name}"/>
                                <DataGridTextColumn Header="Email" Width="200" Binding="{Binding Email}"/>
                                <DataGridTextColumn Header="Статус" Width="100" Binding="{Binding Status}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Секция 6: Вкладки -->
                <Border Style="{StaticResource CardPanelStyle}" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="📑 ВКЛАДКИ (TabControl)" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource RoyalBlueBrush}"
                                   Margin="0,0,0,15"/>

                        <TabControl Height="150" Margin="5">
                            <TabItem Header="Вкладка 1">
                                <StackPanel Margin="10">
                                    <TextBlock Text="Содержимое вкладки 1" 
                                               Foreground="{StaticResource DeepBlueBrush}"/>
                                    <Button Content="Кнопка на вкладке" Width="150" Margin="0,10,0,0"/>
                                </StackPanel>
                            </TabItem>
                            <TabItem Header="Вкладка 2">
                                <StackPanel Margin="10">
                                    <TextBlock Text="Содержимое вкладки 2" 
                                               Foreground="{StaticResource DeepBlueBrush}"/>
                                    <CheckBox Content="Опция на вкладке" IsChecked="True"/>
                                </StackPanel>
                            </TabItem>
                            <TabItem Header="Вкладка 3">
                                <StackPanel Margin="10">
                                    <TextBlock Text="Содержимое вкладки 3" 
                                               Foreground="{StaticResource DeepBlueBrush}"/>
                                </StackPanel>
                            </TabItem>
                        </TabControl>
                    </StackPanel>
                </Border>

                <!-- Секция 7: Прогресс-бар и сообщения -->
                <Border Style="{StaticResource CardPanelStyle}" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="📈 ИНДИКАТОРЫ" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource RoyalBlueBrush}"
                                   Margin="0,0,0,15"/>

                        <TextBlock Text="ProgressBar:" 
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <ProgressBar Value="65" Width="400" Height="20" Margin="5,0,0,10"/>

                        <TextBlock Text="Сообщение об ошибке:" 
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <Border Style="{StaticResource ErrorMessageBorderStyle}" Width="400" Margin="5,0,0,0">
                            <TextBlock Text="❌ Пример сообщения об ошибке" 
                                       Style="{StaticResource ErrorMessageTextStyle}"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Секция 8: Ссылки и текст -->
                <Border Style="{StaticResource CardPanelStyle}" Margin="0,10,0,10">
                    <StackPanel>
                        <TextBlock Text="🔗 ТЕКСТОВЫЕ ЭЛЕМЕНТЫ" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource RoyalBlueBrush}"
                                   Margin="0,0,0,15"/>

                        <TextBlock Text="Обычный текст" 
                                   Margin="5,2"/>

                        <TextBlock Text="Полужирный текст" 
                                   FontWeight="Bold" 
                                   Margin="5,2"/>

                        <TextBlock Text="Ссылка (наведите мышь)" 
                                   Style="{StaticResource LinkTextStyle}"
                                   Margin="5,2"/>

                        <Label Content="Label элемент" Margin="5,2"/>

                        <Label Content="Заголовок (HeaderLabelStyle)" 
                               Style="{StaticResource HeaderLabelStyle}"
                               Margin="5,10,5,2"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>