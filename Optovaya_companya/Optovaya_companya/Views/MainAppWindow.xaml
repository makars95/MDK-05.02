<Window x:Class="Optovaya_companya.Views.MainAppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="OptTorg - Управление торговлей ЛКМ" 
        Height="700" 
        Width="1200"
        MinHeight="500"
        MinWidth="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resource/Theme/DefaultTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{DynamicResource BgGradient}" CornerRadius="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ЗАГОЛОВОК ОКНА -->
            <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" 
                    CornerRadius="15,15,0,0"
                    Background="{DynamicResource BgDark}">
                <Grid>

                    <!-- Кнопки управления окном -->
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Right" 
                                VerticalAlignment="Center"
                                Margin="0,0,10,0">

                    </StackPanel>
                </Grid>
            </Border>

            <!-- ЛЕВАЯ ПАНЕЛЬ -->
            <Border Grid.Row="1" Grid.Column="0" 
                    Background="{DynamicResource BgDark}"
                    CornerRadius="0,0,0,15">
                <DockPanel>
                    <!-- Логотип -->
                    <Border DockPanel.Dock="Top" Padding="0,20,0,20">
                        <StackPanel HorizontalAlignment="Center">
                            <Border Grid.Row="0" 
                                    Style="{DynamicResource LogoBorderStyle}"
                                    Margin="0,0,0,5">
                                <Image Source="Resources/Images/logo2.png" 
                                       Style="{DynamicResource RoundedImageStyle}"/>
                            </Border>
                            <TextBlock Text="OptTorgKrask" 
                                       FontSize="22" 
                                       FontWeight="Bold" 
                                       Foreground="{DynamicResource TextPrimary}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Лакокрасочные материалы" 
                                       FontSize="11" 
                                       Foreground="{DynamicResource TextSecondary}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Навигация -->
                    <ListBox x:Name="NavigationListBox"
                             Style="{DynamicResource NavListBoxStyle}"
                             ItemsSource="{Binding ViewModelsCollection}"
                             SelectedItem="{Binding SelectedViewModel}"
                             DockPanel.Dock="Top"
                             Margin="10,20,10,0"/>

                    <!-- Панель пользователя (нижняя часть левой панели) -->
                    <Border DockPanel.Dock="Bottom" 
                            Background="{DynamicResource BgDark}"
                            Padding="15,15"
                            CornerRadius="0,0,0,15">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="50" Height="50" CornerRadius="25"
                                        Background="{DynamicResource PrimaryBlue}"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="👤" FontSize="28" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock FontSize="14" FontWeight="Bold" 
                                               Foreground="{DynamicResource TextPrimary}"
                                               Text="{Binding UserFullName}"/>
                                    <TextBlock FontSize="11" 
                                               Foreground="{DynamicResource TextSecondary}"
                                               Text="Сотрудник OptTorgKrask"/>
                                </StackPanel>
                            </StackPanel>

                        </StackPanel>
                    </Border>
                </DockPanel>
            </Border>

            <!-- ==================== РАБОЧАЯ ОБЛАСТЬ ==================== -->
            <Border Grid.Row="1" Grid.Column="1" 
                    Background="{DynamicResource BgMedium}"
                    CornerRadius="0,0,15,15">
                <Frame NavigationUIVisibility="Hidden" Content="{Binding SelectedViewModel}"/>
            </Border>

            <!-- Уголок для изменения размера окна -->
            <Border Grid.Row="1" Grid.Column="1" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Bottom"
                    Width="15" Height="15"
                    Background="Transparent"
                    Cursor="SizeNWSE">
            </Border>
        </Grid>
    </Border>
</Window>